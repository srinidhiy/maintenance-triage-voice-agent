# OpenAI
OPENAI_API_KEY=sk-...
TRIAGE_MODEL=gpt-4o        # model used for severity classification
SUMMARY_MODEL=gpt-4o-mini  # model used for ticket summarization
AGENT_MODEL=gpt-4o         # model used for the voice conversation

# Deepgram (STT)
DEEPGRAM_API_KEY=...

# Cartesia (TTS)
CARTESIA_API_KEY=...
CARTESIA_VOICE_ID=71a7ad14-091c-4e8e-a314-022ece01c121  # British Reading Lady (default)

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...

# Ngrok public hostname (no protocol, no trailing slash), e.g. abc123.ngrok.io
PUBLIC_HOST=

# Internal API base URL (default is fine for local development)
API_BASE_URL=http://localhost:8000
